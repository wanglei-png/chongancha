<!-- 首页：宠急查 - 宠物健康决策助手 -->
<view class="page">
  <!-- 右上角"我的"入口 -->
  <view class="profile-entry" bindtap="goProfile">
    <image class="profile-icon" src="/images/icons/profile.svg" mode="aspectFit"></image>
    <text class="profile-text">我的</text>
  </view>

  <!-- 顶部品牌区 -->
  <view class="header">
    <text class="brand-name">宠急查</text>
    <text class="brand-subtitle">宠物健康决策助手</text>
  </view>

  <!-- 症状搜索区 -->
  <view class="search-section">
    <!-- 搜索框 -->
    <view class="search-box {{searchFocused ? 'search-box-focused' : ''}}">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索症状，如：呕吐、腹泻、便秘..."
        placeholder-class="search-placeholder"
        value="{{searchValue}}"
        focus="{{searchFocus}}"
        bindinput="onSearchInput"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        confirm-type="search"
      />
      <!-- 清除按钮 -->
      <view class="search-clear {{searchValue ? 'search-clear-show' : ''}}" bindtap="onClearSearch" catchtap>
        <text class="search-clear-icon">✕</text>
      </view>
    </view>

    <!-- 下拉列表 -->
    <view class="search-dropdown {{showDropdown ? 'search-dropdown-show' : ''}}">
      <!-- 有匹配结果 -->
      <block wx:if="{{searchResults.length > 0}}">
        <view
          class="dropdown-item"
          wx:for="{{searchResults}}"
          wx:key="symptom_id"
          data-symptom-id="{{item.symptom_id || item.id}}"
          data-symptom-name="{{item.symptom_name || item.name}}"
          data-emoji="{{item.emoji}}"
          bindtap="onSelectSymptom"
        >
          <text class="dropdown-item-emoji">{{item.emoji}}</text>
          <text class="dropdown-item-name">{{item.symptom_name || item.name}}</text>
          <text class="dropdown-item-arrow">›</text>
        </view>
      </block>
      <!-- 无匹配结果 -->
      <block wx:elif="{{searchValue && searchResults.length === 0}}">
        <view class="dropdown-empty">
          <text class="dropdown-empty-text">暂无该症状，试试：呕吐、腹泻、皮肤瘙痒</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 中部主按钮区 -->
  <view class="main-action" bindtap="goSymptom" hover-class="main-action-hover">
    <image class="action-icon" src="/images/icons/paw.svg" mode="aspectFit"></image>
    <text class="action-text">我的宠物怎么了？</text>
    <text class="action-hint">点击开始症状自查</text>
  </view>

  <!-- 底部轻提示 -->
  <view class="footer">
    <view class="footer-divider"></view>
    <text class="footer-text">3分钟理清：观察什么、禁止什么、何时就医</text>
  </view>
</view>
