/* 首页样式 - 宠安查 */

page {
  background-color: #ffffff;
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.page {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 0 40rpx;
  box-sizing: border-box;
  background-color: #ffffff;
}

/* ===== 右上角"我的"入口 ===== */
.profile-entry {
  position: absolute;
  top: 40rpx;
  right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 16rpx;
  border-radius: 30rpx;
  background-color: #f5f5f7;
  z-index: 10;
  min-width: 80rpx;
}

.profile-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.profile-text {
  font-size: 22rpx;
  color: #8e8e93;
  font-weight: 400;
  line-height: 1;
}

/* ===== 顶部品牌区 ===== */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  padding-bottom: 40rpx;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 4rpx;
  line-height: 1.3;
}

.brand-subtitle {
  font-size: 28rpx;
  color: #8e8e93;
  margin-top: 12rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
}

/* ===== 症状搜索区 ===== */
.search-section {
  width: 100%;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 20;
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid #e5e5ea;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.search-box-focused {
  border-color: #2B7AE8;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #1a1a1a;
  background: transparent;
  border: none;
  outline: none;
}

.search-placeholder {
  font-size: 28rpx;
  color: #c7c7cc;
}

/* 清除按钮 */
.search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #c7c7cc;
  display: none;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.search-clear-show {
  display: flex;
}

.search-clear-icon {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 700;
  line-height: 1;
}

/* 下拉列表 */
.search-dropdown {
  width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  max-height: 400rpx;
  overflow-y: auto;
  margin-top: 8rpx;
  display: none;
  position: absolute;
  left: 0;
  right: 0;
  z-index: 30;
}

.search-dropdown-show {
  display: block;
}

/* 下拉列表项 */
.dropdown-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #f2f2f7;
  transition: background-color 0.15s ease;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background-color: #f5f5f7;
}

.dropdown-item-emoji {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  line-height: 1;
}

.dropdown-item-name {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 400;
}

.dropdown-item-arrow {
  font-size: 36rpx;
  color: #c7c7cc;
  flex-shrink: 0;
  margin-left: 12rpx;
  font-weight: 300;
  line-height: 1;
}

/* 无匹配提示 */
.dropdown-empty {
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dropdown-empty-text {
  font-size: 26rpx;
  color: #8e8e93;
  text-align: center;
  line-height: 1.5;
}

/* ===== 中部主按钮 ===== */
.main-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 40vh;
  min-height: 400rpx;
  max-height: 640rpx;
  background: linear-gradient(145deg, #2B7AE8 0%, #1a6ad6 100%);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(43, 122, 232, 0.3);
  cursor: pointer;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.main-action::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.main-action::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 50%;
}

.main-action-hover {
  opacity: 0.9;
  transform: scale(0.97);
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 24rpx;
}

.action-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 3rpx;
  line-height: 1.4;
}

.action-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 16rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ===== 底部提示区 ===== */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
  padding-top: 40rpx;
  width: 100%;
}

.footer-divider {
  width: 48rpx;
  height: 4rpx;
  background-color: #2B7AE8;
  border-radius: 2rpx;
  margin-bottom: 24rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  line-height: 1.6;
  letter-spacing: 1rpx;
  font-weight: 500;
}
