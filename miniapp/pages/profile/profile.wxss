/* 个人中心样式 */

page {
  background-color: #f8f9fa;
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
  box-sizing: border-box;
  background-color: #f8f9fa;
}

/* ===== 顶部用户信息 ===== */
.user-section {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background-color: #f0f0f0;
}

.user-avatar-img {
  width: 100%;
  height: 100%;
}

.user-avatar-placeholder {
  width: 100%;
  height: 100%;
  background-color: #e8e8ed;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar-placeholder-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #8e8e93;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #8e8e93;
  display: block;
}

.user-arrow {
  font-size: 40rpx;
  color: #c7c7cc;
  font-weight: 300;
}

/* ===== 区域通用 ===== */
.section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.add-btn {
  color: #2B7AE8;
  font-size: 28rpx;
  font-weight: 500;
}

.section-body {
  padding: 8rpx 0;
}

/* ===== 加载/空状态 ===== */
.loading-tip {
  text-align: center;
  color: #8e8e93;
  padding: 48rpx 0;
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 48rpx 0;
  font-size: 28rpx;
}

/* ===== 宠物卡片（API 版） ===== */
.pet-list {
  padding: 0;
}

.pet-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f5f5f7;
}

.pet-card:last-child {
  border-bottom: none;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 4rpx;
}

.pet-detail {
  font-size: 24rpx;
  color: #8e8e93;
  display: block;
  margin-top: 6rpx;
}

.pet-actions {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.edit-btn {
  font-size: 26rpx;
  color: #2B7AE8;
  padding: 8rpx 0;
}

.delete-btn {
  font-size: 26rpx;
  color: #FF4D4F;
  padding: 8rpx 0;
}

/* ===== 订阅状态 ===== */
.sub-status-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}

.sub-status-left {
  flex: 1;
}

.sub-status-label {
  font-size: 26rpx;
  color: #8e8e93;
  display: block;
  margin-bottom: 8rpx;
}

.sub-status-value {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
}

.sub-status-active {
  color: #34C759;
}

.sub-status-inactive {
  color: #8e8e93;
}

.sub-status-right {
  flex-shrink: 0;
}

.sub-status-expire {
  font-size: 24rpx;
  color: #8e8e93;
}

.sub-status-btn {
  padding: 16rpx 36rpx;
  border: 2rpx solid #2B7AE8;
  border-radius: 40rpx;
}

.sub-status-btn-text {
  font-size: 26rpx;
  color: #2B7AE8;
  font-weight: 600;
}

/* ===== 底部链接 ===== */
.footer-links {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
}

.footer-link {
  font-size: 24rpx;
  color: #8e8e93;
}

.footer-link-sep {
  font-size: 24rpx;
  color: #d1d1d6;
  margin: 0 20rpx;
}

/* ===== 订阅选择弹窗 ===== */
.sub-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.sub-overlay-show {
  opacity: 1;
  pointer-events: auto;
}

.sub-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  padding-bottom: 48rpx;
}

.sub-modal-show {
  transform: translateY(0);
}

.sub-modal-handle {
  width: 48rpx;
  height: 6rpx;
  background-color: #d1d1d6;
  border-radius: 3rpx;
  margin: 16rpx auto 24rpx;
}

.sub-modal-content {
  padding: 0 40rpx;
}

.sub-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
}

.sub-option {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border: 2rpx solid #e8e8ed;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.sub-option-active {
  border-color: #2B7AE8;
  background-color: #f8fbff;
}

.sub-option-info {
  flex: 1;
}

.sub-option-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.sub-option-desc {
  font-size: 24rpx;
  color: #8e8e93;
  display: block;
}

.sub-option-price {
  text-align: right;
  margin-right: 20rpx;
}

.sub-option-price-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF3B30;
}

.sub-option-price-unit {
  font-size: 24rpx;
  color: #8e8e93;
}

.sub-option-tag {
  position: absolute;
  top: -12rpx;
  right: 24rpx;
  padding: 4rpx 16rpx;
  background-color: #FF3B30;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
}

.sub-option-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d1d6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sub-option-check-active {
  border-color: #2B7AE8;
  background-color: #2B7AE8;
}

.sub-check-mark {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
}

.sub-confirm-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(145deg, #2B7AE8 0%, #1a6ad6 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(43, 122, 232, 0.3);
}

.sub-confirm-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.sub-cancel-text {
  font-size: 28rpx;
  color: #8e8e93;
  display: block;
  text-align: center;
  margin-top: 24rpx;
  padding: 16rpx 0;
}
