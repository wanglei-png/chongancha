/* 症状选择页样式 */

page {
  background-color: #f8f9fa;
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 32rpx;
  box-sizing: border-box;
  background-color: #f8f9fa;
}

/* ===== 顶部引导 ===== */
.guide {
  padding: 40rpx 0 32rpx 0;
}

.guide-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
}

/* ===== 加载/错误状态 ===== */
.loading-state,
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  flex: 1;
}

.loading-text {
  font-size: 28rpx;
  color: #8e8e93;
}

.error-text {
  font-size: 28rpx;
  color: #8e8e93;
  margin-bottom: 24rpx;
}

.retry-btn {
  padding: 16rpx 48rpx;
  border: 2rpx solid #2B7AE8;
  border-radius: 40rpx;
}

.retry-btn-text {
  font-size: 28rpx;
  color: #2B7AE8;
  font-weight: 500;
}

/* ===== 症状卡片列表 ===== */
.symptom-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  flex: 1;
  padding-bottom: 160rpx;
}

.symptom-card {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  border: 2rpx solid #e8e8ed;
  transition: all 0.2s ease;
  position: relative;
  min-height: 120rpx;
}

.symptom-card-active {
  border-color: #2B7AE8;
  background-color: #f0f6ff;
  box-shadow: 0 4rpx 16rpx rgba(43, 122, 232, 0.12);
}

.symptom-emoji {
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  width: 56rpx;
  text-align: center;
}

.symptom-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  flex: 1;
}

/* 审核中标签 */
.symptom-audit-badge {
  padding: 4rpx 14rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.symptom-audit-badge-text {
  font-size: 22rpx;
  color: #8e8e93;
  font-weight: 400;
}

.symptom-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #c7c7cc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.symptom-check-active {
  background-color: #2B7AE8;
  border-color: #2B7AE8;
}

.check-mark {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
}

/* ===== 底部按钮 ===== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx 48rpx;
  background-color: #f8f9fa;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.analyze-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.analyze-btn-active {
  background: linear-gradient(145deg, #2B7AE8 0%, #1a6ad6 100%);
  box-shadow: 0 8rpx 24rpx rgba(43, 122, 232, 0.3);
}

.analyze-btn-disabled {
  background-color: #e8e8ed;
}

.analyze-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}
