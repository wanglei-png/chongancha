page {
  background-color: #f8f9fa;
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background-color: #f8f9fa;
}

.content {
  max-width: 700rpx;
  margin: 0 auto;
}

.section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
}

.section-body {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.8;
  display: block;
  white-space: pre-line;
}

.footer-note {
  text-align: center;
  padding: 32rpx 0;
}

.footer-note-text {
  font-size: 24rpx;
  color: #8e8e93;
}
